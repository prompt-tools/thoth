{
  "name": "thoth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint -- --max-warnings=0 && npm test && NODE_ENV=production npm run build",
    "eval": "tsx .research/scripts/eval-agent.mjs --seeds .research/eval-seeds/portrait-seeds.txt",
    "eval:report": "tsx .research/scripts/eval-report.mjs",
    "analyze-prompts": "tsx .research/scripts/analyze-portrait-prompts.mjs",
    "compare-corpus": "tsx .research/scripts/compare-eval-corpus.mjs",
    "structure-plan": "tsx .research/scripts/portrait-structure-plan.mjs",
    "sample-seeds": "tsx .research/scripts/sample-portrait-seeds.mjs"
  },
  "engines": {
    "node": ">=22.6"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "next": "15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@langfuse/client": "^5.4.1",
    "@langfuse/otel": "^5.4.1",
    "@langfuse/tracing": "^5.4.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
